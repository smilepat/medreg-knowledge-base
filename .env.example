# .env 예시 — 실제 값은 .env에 넣으세요 (.env는 git에서 제외됨)
# 국가법령정보 Open API OC 키: https://open.law.go.kr 에서 발급 + 호출 PC의 IP 등록
LAW_OC=your_oc_id

# Supabase(pgvector) — 둘 중 하나만 채우면 됨 (전체 URL 권장)
SUPABASE_DB_URL=postgresql://postgres.<ref>:<password>@aws-...pooler.supabase.com:5432/postgres
SUPABASE_DB_PASSWORD=
